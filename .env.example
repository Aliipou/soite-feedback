# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://soite_app:changeme@db:5432/soite_feedback
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@redis:6379/0
REDIS_PASSWORD=changeme

# ── Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# IMPORTANT: SECRET_KEY and PGCRYPTO_KEY must be DIFFERENT values and NEVER committed.
SECRET_KEY=replace_with_64_hex_chars_output_of_secrets_token_hex_32
PGCRYPTO_KEY=replace_with_different_64_hex_chars_output_of_secrets_token_hex_32

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_VERSION=1.0.0
DEBUG=false
ADMIN_EMAIL=admin@soite.fi
